rules_version = '2';

// SignaalBrug v2 — DEMO-GRADE rules, not a production security review.
// Public content is world-readable; writes require (anonymous) auth.
service cloud.firestore {
  match /databases/{database}/documents {
    // Portal content — readable without sign-in
    match /faq/{id}        { allow read: if true; allow write: if request.auth != null; }
    match /resources/{id}  { allow read: if true; allow write: if request.auth != null; }
    match /locations/{id}  { allow read: if true; allow write: if request.auth != null; }
    match /meta/{id}       { allow read: if true; allow write: if request.auth != null; }

    // Operational data — anonymous auth required (the portal signs in anonymously)
    match /cases/{id}      { allow read, write: if request.auth != null; }
    match /volunteers/{id} { allow read, write: if request.auth != null; }
    match /searchLog/{id}  { allow read, write: if request.auth != null; }
    match /insights/{id}   { allow read, write: if request.auth != null; }

    // Demo snapshot mirror (single doc used by the in-app "Connect Firebase" switch)
    match /signaalbrug/{id} { allow read, write: if request.auth != null; }
  }
}
