# SignaalBrug v2 — environment template.
# The app runs fully on the in-browser dataset without any of these.
# Paste your Firebase web config to mirror data to Firestore (see docs/SETUP_KIRAN.md).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI provider for the AiAdapter: mock | gemini | anthropic
# "mock" is deterministic and never fails on stage — recommended for demos.
VITE_AI_PROVIDER=mock
